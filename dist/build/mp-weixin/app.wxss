:root{--primary: #FFB6C1;--primary-dark: #FF69B4;--secondary: #98D8C8;--accent: #F7DC6F;--bg: #FFF9FB;--card: #FFFFFF;--text: #5D4E6D;--text-light: #9B8AA6;--border: #F0E6F5}page{font-family:-apple-system,BlinkMacSystemFont,Segoe UI,PingFang SC,sans-serif;background:linear-gradient(180deg,#fff0f5,#fff9fb);color:var(--text)}.btn-cute{background:linear-gradient(135deg,#ffb6c1,#ff69b4);color:#fff;border:none;padding:14px 32px;border-radius:25px;font-size:15px;font-weight:600;box-shadow:0 4px 15px rgba(255,182,193,.4);transition:all .2s}.btn-cute:active{transform:scale(.96);box-shadow:0 2px 8px rgba(255,182,193,.3)}.fab-cute{position:fixed;right:20px;bottom:100px;width:56px;height:56px;background:linear-gradient(135deg,#ffb6c1,#ff69b4);border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 20px rgba(255,182,193,.4);z-index:100}.fab-cute:before{content:"+";font-size:28px;color:#fff;font-weight:300}.card-cute{background:#fff;border-radius:20px;padding:20px;box-shadow:0 4px 20px rgba(93,78,109,.06);border:1px solid var(--border)}.input-cute{background:#fff5f8;border:2px solid #F0E6F5;border-radius:16px;padding:14px 18px;font-size:15px;color:var(--text);transition:all .2s}.input-cute:focus{border-color:var(--primary);background:#fff}.tag-cute{background:linear-gradient(135deg,#ffe4e9,#fff0f3);color:var(--primary-dark);padding:6px 14px;border-radius:20px;font-size:12px;font-weight:500}.empty-cute{text-align:center;padding:60px 40px}.empty-cute-icon{font-size:80px;margin-bottom:20px;display:block}.empty-cute-text{font-size:18px;font-weight:600;color:var(--text);margin-bottom:8px}.empty-cute-hint{font-size:14px;color:var(--text-light)}.uni-tabbar .uni-tabbar__item{font-size:13px!important}.uni-tabbar .uni-tabbar__label{font-size:13px!important;font-weight:500}
page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}