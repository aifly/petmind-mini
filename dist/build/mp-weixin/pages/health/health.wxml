<view class="container data-v-a9be3c4e"><view class="header data-v-a9be3c4e"><text class="title data-v-a9be3c4e">健康记录</text><text class="subtitle data-v-a9be3c4e">关注宠物健康每一天</text></view><view class="health-cards data-v-a9be3c4e"><view class="health-card data-v-a9be3c4e"><text class="card-icon data-v-a9be3c4e">❤️</text><text class="card-value data-v-a9be3c4e">{{a}} kg</text><text class="card-label data-v-a9be3c4e">体重</text></view><view class="health-card data-v-a9be3c4e"><text class="card-icon data-v-a9be3c4e">🌡️</text><text class="card-value data-v-a9be3c4e">{{b}} °C</text><text class="card-label data-v-a9be3c4e">体温</text></view><view class="health-card data-v-a9be3c4e"><text class="card-icon data-v-a9be3c4e">💩</text><text class="card-value data-v-a9be3c4e">{{c}}</text><text class="card-label data-v-a9be3c4e">排便</text></view></view><view class="section-title data-v-a9be3c4e"><text class="data-v-a9be3c4e">健康记录</text></view><view wx:if="{{d}}" class="record-list data-v-a9be3c4e"><view wx:for="{{e}}" wx:for-item="record" wx:key="e" class="record-card data-v-a9be3c4e"><view class="record-icon data-v-a9be3c4e"><text class="data-v-a9be3c4e">{{record.a}}</text></view><view class="record-content data-v-a9be3c4e"><text class="record-title data-v-a9be3c4e">{{record.b}}</text><text class="record-desc data-v-a9be3c4e">{{record.c}}</text></view><text class="record-date data-v-a9be3c4e">{{record.d}}</text></view></view><view wx:else class="empty-state data-v-a9be3c4e"><text class="empty-text data-v-a9be3c4e">暂无健康记录</text><text class="empty-hint data-v-a9be3c4e">点击下方按钮添加记录</text></view><view class="fab data-v-a9be3c4e" bindtap="{{f}}"><text class="fab-icon data-v-a9be3c4e">+</text></view><view wx:if="{{g}}" class="modal-mask data-v-a9be3c4e" bindtap="{{z}}"><view class="modal data-v-a9be3c4e" catchtap="{{y}}"><view class="modal-header data-v-a9be3c4e"><text class="modal-title data-v-a9be3c4e">添加健康记录</text><text class="modal-close data-v-a9be3c4e" bindtap="{{h}}">×</text></view><view class="form-group data-v-a9be3c4e"><text class="label data-v-a9be3c4e">宠物</text><picker class="data-v-a9be3c4e" range="{{j}}" range-key="name" bindchange="{{k}}"><view class="picker data-v-a9be3c4e"><text class="data-v-a9be3c4e">{{i}}</text></view></picker></view><view class="form-group data-v-a9be3c4e"><text class="label data-v-a9be3c4e">健康类型</text><picker class="data-v-a9be3c4e" range="{{m}}" bindchange="{{n}}"><view class="picker data-v-a9be3c4e"><text class="data-v-a9be3c4e">{{l}}</text></view></picker></view><view wx:if="{{o}}" class="form-group data-v-a9be3c4e"><text class="label data-v-a9be3c4e">体重 (kg)</text><input class="input data-v-a9be3c4e" type="number" placeholder="请输入体重" value="{{p}}" bindinput="{{q}}"/></view><view wx:if="{{r}}" class="form-group data-v-a9be3c4e"><text class="label data-v-a9be3c4e">体温 (°C)</text><input class="input data-v-a9be3c4e" type="number" placeholder="请输入体温" value="{{s}}" bindinput="{{t}}"/></view><view class="form-group data-v-a9be3c4e"><text class="label data-v-a9be3c4e">备注</text><block wx:if="{{r0}}"><textarea class="textarea data-v-a9be3c4e" placeholder="请输入备注" value="{{v}}" bindinput="{{w}}"/></block></view><button class="submit-btn data-v-a9be3c4e" bindtap="{{x}}">保存</button></view></view></view>