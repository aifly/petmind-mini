<view class="container data-v-dcc1577d"><view class="page-header data-v-dcc1577d"><text class="page-title data-v-dcc1577d">健康记录</text><text class="page-desc data-v-dcc1577d">关注宠物健康每一天</text></view><view wx:if="{{a}}" class="pet-select data-v-dcc1577d"><picker class="data-v-dcc1577d" range="{{c}}" range-key="name" bindchange="{{d}}"><view class="pet-picker data-v-dcc1577d"><text class="pet-picker-label data-v-dcc1577d">当前宠物：</text><text class="pet-picker-value data-v-dcc1577d">{{b}}</text><text class="pet-picker-arrow data-v-dcc1577d">›</text></view></picker></view><view wx:if="{{e}}" class="health-cards data-v-dcc1577d"><view class="health-card data-v-dcc1577d"><text class="card-icon data-v-dcc1577d">⚖️</text><text class="card-value data-v-dcc1577d">{{f}} kg</text><text class="card-label data-v-dcc1577d">体重</text></view><view class="health-card data-v-dcc1577d"><text class="card-icon data-v-dcc1577d">🌡️</text><text class="card-value data-v-dcc1577d">{{g}} °C</text><text class="card-label data-v-dcc1577d">体温</text></view><view class="health-card data-v-dcc1577d"><text class="card-icon data-v-dcc1577d">💩</text><text class="card-value data-v-dcc1577d">正常</text><text class="card-label data-v-dcc1577d">排便</text></view></view><view wx:if="{{h}}" class="section-title data-v-dcc1577d"><text class="data-v-dcc1577d">记录详情</text></view><view wx:if="{{i}}" class="record-list data-v-dcc1577d"><view wx:for="{{j}}" wx:for-item="record" wx:key="f" class="record-card data-v-dcc1577d"><view class="record-icon data-v-dcc1577d"><text class="data-v-dcc1577d">{{record.a}}</text></view><view class="record-content data-v-dcc1577d"><text class="record-title data-v-dcc1577d">{{record.b}}</text><text wx:if="{{record.c}}" class="record-desc data-v-dcc1577d">{{record.d}}</text></view><text class="record-date data-v-dcc1577d">{{record.e}}</text></view></view><view wx:else class="empty-state data-v-dcc1577d"><text class="empty-title data-v-dcc1577d">暂无健康记录</text><text class="empty-desc data-v-dcc1577d">点击下方按钮添加记录</text></view><view wx:if="{{k}}" class="fab data-v-dcc1577d" bindtap="{{l}}"><text class="fab-icon data-v-dcc1577d">+</text></view><view wx:if="{{m}}" class="modal-mask data-v-dcc1577d" bindtap="{{F}}"><view class="modal data-v-dcc1577d" catchtap="{{E}}"><view class="modal-header data-v-dcc1577d"><text class="modal-title data-v-dcc1577d">添加健康记录</text><text class="modal-close data-v-dcc1577d" bindtap="{{n}}">×</text></view><view class="form-group data-v-dcc1577d"><text class="label data-v-dcc1577d">宠物</text><picker class="data-v-dcc1577d" range="{{p}}" range-key="name" bindchange="{{q}}"><view class="picker data-v-dcc1577d"><text class="data-v-dcc1577d">{{o}}</text></view></picker></view><view class="form-group data-v-dcc1577d"><text class="label data-v-dcc1577d">记录类型</text><picker class="data-v-dcc1577d" range="{{s}}" bindchange="{{t}}"><view class="picker data-v-dcc1577d"><text class="data-v-dcc1577d">{{r}}</text></view></picker></view><view wx:if="{{v}}" class="form-group data-v-dcc1577d"><text class="label data-v-dcc1577d">体重 (kg)</text><input class="input data-v-dcc1577d" type="digit" placeholder="请输入体重" value="{{w}}" bindinput="{{x}}"/></view><view wx:if="{{y}}" class="form-group data-v-dcc1577d"><text class="label data-v-dcc1577d">体温 (°C)</text><input class="input data-v-dcc1577d" type="digit" placeholder="请输入体温" value="{{z}}" bindinput="{{A}}"/></view><view class="form-group data-v-dcc1577d"><text class="label data-v-dcc1577d">备注</text><block wx:if="{{r0}}"><textarea class="textarea data-v-dcc1577d" placeholder="请输入备注" value="{{B}}" bindinput="{{C}}"/></block></view><button class="submit-btn data-v-dcc1577d" bindtap="{{D}}">保存</button></view></view></view>