<view class="container data-v-4a61c244"><view class="header data-v-4a61c244"><text class="title data-v-4a61c244">健康记录</text><text class="subtitle data-v-4a61c244">关注宠物健康每一天</text></view><view class="health-cards data-v-4a61c244"><view class="health-card data-v-4a61c244"><text class="card-icon data-v-4a61c244">❤️</text><text class="card-value data-v-4a61c244">{{a}} kg</text><text class="card-label data-v-4a61c244">体重</text></view><view class="health-card data-v-4a61c244"><text class="card-icon data-v-4a61c244">🌡️</text><text class="card-value data-v-4a61c244">{{b}} °C</text><text class="card-label data-v-4a61c244">体温</text></view><view class="health-card data-v-4a61c244"><text class="card-icon data-v-4a61c244">💩</text><text class="card-value data-v-4a61c244">{{c}}</text><text class="card-label data-v-4a61c244">排便</text></view></view><view class="section-title data-v-4a61c244"><text class="data-v-4a61c244">健康记录</text></view><view wx:if="{{d}}" class="record-list data-v-4a61c244"><view wx:for="{{e}}" wx:for-item="record" wx:key="e" class="record-card data-v-4a61c244"><view class="record-icon data-v-4a61c244"><text class="data-v-4a61c244">{{record.a}}</text></view><view class="record-content data-v-4a61c244"><text class="record-title data-v-4a61c244">{{record.b}}</text><text class="record-desc data-v-4a61c244">{{record.c}}</text></view><text class="record-date data-v-4a61c244">{{record.d}}</text></view></view><view wx:else class="empty-state data-v-4a61c244"><text class="empty-text data-v-4a61c244">暂无健康记录</text><text class="empty-hint data-v-4a61c244">点击下方按钮添加记录</text></view><view class="fab data-v-4a61c244" bindtap="{{f}}"><text class="fab-icon data-v-4a61c244">+</text></view><view wx:if="{{g}}" class="modal-mask data-v-4a61c244" bindtap="{{z}}"><view class="modal data-v-4a61c244" catchtap="{{y}}"><view class="modal-header data-v-4a61c244"><text class="modal-title data-v-4a61c244">添加健康记录</text><text class="modal-close data-v-4a61c244" bindtap="{{h}}">×</text></view><view class="form-group data-v-4a61c244"><text class="label data-v-4a61c244">宠物</text><picker class="data-v-4a61c244" range="{{j}}" range-key="name" bindchange="{{k}}"><view class="picker data-v-4a61c244"><text class="data-v-4a61c244">{{i}}</text></view></picker></view><view class="form-group data-v-4a61c244"><text class="label data-v-4a61c244">健康类型</text><picker class="data-v-4a61c244" range="{{m}}" bindchange="{{n}}"><view class="picker data-v-4a61c244"><text class="data-v-4a61c244">{{l}}</text></view></picker></view><view wx:if="{{o}}" class="form-group data-v-4a61c244"><text class="label data-v-4a61c244">体重 (kg)</text><input class="input data-v-4a61c244" type="number" placeholder="请输入体重" value="{{p}}" bindinput="{{q}}"/></view><view wx:if="{{r}}" class="form-group data-v-4a61c244"><text class="label data-v-4a61c244">体温 (°C)</text><input class="input data-v-4a61c244" type="number" placeholder="请输入体温" value="{{s}}" bindinput="{{t}}"/></view><view class="form-group data-v-4a61c244"><text class="label data-v-4a61c244">备注</text><block wx:if="{{r0}}"><textarea class="textarea data-v-4a61c244" placeholder="请输入备注" value="{{v}}" bindinput="{{w}}"/></block></view><button class="submit-btn data-v-4a61c244" bindtap="{{x}}">保存</button></view></view></view>