<view class="container data-v-5056d4fa"><view class="header data-v-5056d4fa"><text class="title data-v-5056d4fa">添加宠物</text></view><view class="form data-v-5056d4fa"><view class="form-group data-v-5056d4fa"><text class="label data-v-5056d4fa">宠物名称 *</text><input class="input data-v-5056d4fa" placeholder="请输入宠物名称" value="{{a}}" bindinput="{{b}}"/></view><view class="form-group data-v-5056d4fa"><text class="label data-v-5056d4fa">宠物类型 *</text><picker class="data-v-5056d4fa" range="{{d}}" range-key="name" bindchange="{{e}}"><view class="picker data-v-5056d4fa"><text class="data-v-5056d4fa">{{c}}</text></view></picker></view><view class="form-group data-v-5056d4fa"><text class="label data-v-5056d4fa">品种</text><input class="input data-v-5056d4fa" placeholder="请输入品种（选填）" value="{{f}}" bindinput="{{g}}"/></view><view class="form-group data-v-5056d4fa"><text class="label data-v-5056d4fa">性别</text><picker class="data-v-5056d4fa" range="{{i}}" bindchange="{{j}}"><view class="picker data-v-5056d4fa"><text class="data-v-5056d4fa">{{h}}</text></view></picker></view><view class="form-group data-v-5056d4fa"><text class="label data-v-5056d4fa">出生日期</text><picker class="data-v-5056d4fa" mode="date" value="{{l}}" bindchange="{{m}}"><view class="picker data-v-5056d4fa"><text class="data-v-5056d4fa">{{k}}</text></view></picker></view><view class="form-group data-v-5056d4fa"><text class="label data-v-5056d4fa">体重 (kg)</text><input class="input data-v-5056d4fa" type="number" placeholder="请输入体重（选填）" value="{{n}}" bindinput="{{o}}"/></view><view class="form-group data-v-5056d4fa"><text class="label data-v-5056d4fa">备注</text><block wx:if="{{r0}}"><textarea class="textarea data-v-5056d4fa" placeholder="请输入备注（选填）" value="{{p}}" bindinput="{{q}}"/></block></view><button class="submit-btn data-v-5056d4fa" bindtap="{{r}}">保存</button></view></view>