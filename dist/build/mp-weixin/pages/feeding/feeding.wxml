<view class="container data-v-fbf755e2"><view class="header data-v-fbf755e2"><text class="title data-v-fbf755e2">喂养记录</text><text class="subtitle data-v-fbf755e2">记录每一次喂养</text></view><view wx:if="{{a}}" class="record-list data-v-fbf755e2"><view wx:for="{{b}}" wx:for-item="record" wx:key="e" class="record-card data-v-fbf755e2"><view class="record-time data-v-fbf755e2"><text class="time data-v-fbf755e2">{{record.a}}</text><text class="date data-v-fbf755e2">{{record.b}}</text></view><view class="record-content data-v-fbf755e2"><text class="food-type data-v-fbf755e2">{{record.c}}</text><text class="amount data-v-fbf755e2">{{record.d}}g</text></view></view></view><view wx:else class="empty-state data-v-fbf755e2"><text class="empty-text data-v-fbf755e2">暂无喂养记录</text><text class="empty-hint data-v-fbf755e2">点击下方按钮添加记录</text></view><view class="fab data-v-fbf755e2" bindtap="{{c}}"><text class="fab-icon data-v-fbf755e2">+</text></view><view wx:if="{{d}}" class="modal-mask data-v-fbf755e2" bindtap="{{p}}"><view class="modal data-v-fbf755e2" catchtap="{{o}}"><view class="modal-header data-v-fbf755e2"><text class="modal-title data-v-fbf755e2">添加喂养记录</text><text class="modal-close data-v-fbf755e2" bindtap="{{e}}">×</text></view><view class="form-group data-v-fbf755e2"><text class="label data-v-fbf755e2">宠物</text><picker class="data-v-fbf755e2" range="{{g}}" range-key="name" bindchange="{{h}}"><view class="picker data-v-fbf755e2"><text class="data-v-fbf755e2">{{f}}</text></view></picker></view><view class="form-group data-v-fbf755e2"><text class="label data-v-fbf755e2">食物类型</text><picker class="data-v-fbf755e2" range="{{j}}" bindchange="{{k}}"><view class="picker data-v-fbf755e2"><text class="data-v-fbf755e2">{{i}}</text></view></picker></view><view class="form-group data-v-fbf755e2"><text class="label data-v-fbf755e2">数量 (g)</text><input class="input data-v-fbf755e2" type="number" placeholder="请输入数量" value="{{l}}" bindinput="{{m}}"/></view><button class="submit-btn data-v-fbf755e2" bindtap="{{n}}">保存</button></view></view></view>