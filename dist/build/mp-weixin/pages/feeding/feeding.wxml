<view class="container data-v-50d08188"><view class="header data-v-50d08188"><text class="title data-v-50d08188">喂养记录</text><text class="subtitle data-v-50d08188">记录每一次喂养</text></view><view wx:if="{{a}}" class="loading data-v-50d08188"><text class="data-v-50d08188">加载中...</text></view><view wx:elif="{{b}}" class="record-list data-v-50d08188"><view wx:for="{{c}}" wx:for-item="record" wx:key="f" class="record-card data-v-50d08188"><view class="record-icon data-v-50d08188"><text class="data-v-50d08188">{{record.a}}</text></view><view class="record-content data-v-50d08188"><text class="food-type data-v-50d08188">{{record.b}}</text><text class="pet-name data-v-50d08188">{{record.c}}</text></view><view class="record-right data-v-50d08188"><text class="amount data-v-50d08188">{{record.d}}g</text><text class="time data-v-50d08188">{{record.e}}</text></view></view></view><view wx:else class="empty-state data-v-50d08188"><text class="empty-text data-v-50d08188">暂无喂养记录</text><text class="empty-hint data-v-50d08188">点击下方按钮添加记录</text></view><view class="fab data-v-50d08188" bindtap="{{d}}"><text class="fab-icon data-v-50d08188">+</text></view><view wx:if="{{e}}" class="modal-mask data-v-50d08188" bindtap="{{q}}"><view class="modal data-v-50d08188" catchtap="{{p}}"><view class="modal-header data-v-50d08188"><text class="modal-title data-v-50d08188">添加喂养记录</text><text class="modal-close data-v-50d08188" bindtap="{{f}}">×</text></view><view class="form-group data-v-50d08188"><text class="label data-v-50d08188">宠物</text><picker class="data-v-50d08188" range="{{h}}" range-key="name" bindchange="{{i}}"><view class="picker data-v-50d08188"><text class="data-v-50d08188">{{g}}</text></view></picker></view><view class="form-group data-v-50d08188"><text class="label data-v-50d08188">食物类型</text><picker class="data-v-50d08188" range="{{k}}" bindchange="{{l}}"><view class="picker data-v-50d08188"><text class="data-v-50d08188">{{j}}</text></view></picker></view><view class="form-group data-v-50d08188"><text class="label data-v-50d08188">数量 (g)</text><input class="input data-v-50d08188" type="number" placeholder="请输入数量" value="{{m}}" bindinput="{{n}}"/></view><button class="submit-btn data-v-50d08188" bindtap="{{o}}">保存</button></view></view></view>