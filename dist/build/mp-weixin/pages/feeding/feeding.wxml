<view class="container data-v-f095a309"><view class="page-header data-v-f095a309"><text class="page-title data-v-f095a309">喂养记录</text><text class="page-desc data-v-f095a309">记录每一次喂食</text></view><view wx:if="{{a}}" class="pet-select data-v-f095a309"><picker class="data-v-f095a309" range="{{c}}" range-key="name" bindchange="{{d}}"><view class="pet-picker data-v-f095a309"><text class="pet-picker-label data-v-f095a309">当前宠物：</text><text class="pet-picker-value data-v-f095a309">{{b}}</text><text class="pet-picker-arrow data-v-f095a309">›</text></view></picker></view><view wx:if="{{e}}" class="record-list data-v-f095a309"><view wx:for="{{f}}" wx:for-item="record" wx:key="d" class="record-card data-v-f095a309"><view class="record-left data-v-f095a309"><text class="record-icon data-v-f095a309">🍚</text><view class="record-info data-v-f095a309"><text class="record-type data-v-f095a309">{{record.a}}</text><text class="record-time data-v-f095a309">{{record.b}}</text></view></view><view class="record-right data-v-f095a309"><text class="record-amount data-v-f095a309">{{record.c}}g</text></view></view></view><view wx:else class="empty-state data-v-f095a309"><text class="empty-title data-v-f095a309">暂无喂养记录</text><text class="empty-desc data-v-f095a309">点击下方按钮添加记录</text></view><view wx:if="{{g}}" class="fab data-v-f095a309" bindtap="{{h}}"><text class="fab-icon data-v-f095a309">+</text></view><view wx:if="{{i}}" class="modal-mask data-v-f095a309" bindtap="{{v}}"><view class="modal data-v-f095a309" catchtap="{{t}}"><view class="modal-header data-v-f095a309"><text class="modal-title data-v-f095a309">添加喂养记录</text><text class="modal-close data-v-f095a309" bindtap="{{j}}">×</text></view><view class="form-group data-v-f095a309"><text class="label data-v-f095a309">宠物</text><picker class="data-v-f095a309" range="{{l}}" range-key="name" bindchange="{{m}}"><view class="picker data-v-f095a309"><text class="data-v-f095a309">{{k}}</text></view></picker></view><view class="form-group data-v-f095a309"><text class="label data-v-f095a309">食物类型</text><picker class="data-v-f095a309" range="{{o}}" bindchange="{{p}}"><view class="picker data-v-f095a309"><text class="data-v-f095a309">{{n}}</text></view></picker></view><view class="form-group data-v-f095a309"><text class="label data-v-f095a309">数量 (g)</text><input class="input data-v-f095a309" type="number" placeholder="请输入数量" value="{{q}}" bindinput="{{r}}"/></view><button class="submit-btn data-v-f095a309" bindtap="{{s}}">保存</button></view></view></view>